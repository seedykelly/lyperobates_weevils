  author = {Haran, J. and Li, X. and Allio, R. and Shin, S. and Benoit, L. and Oberprieler, R. G. and Farrell, B. D. and Brown, S. D. J. and Leschen, R. A. B. and Kergoat, G. J. and McKenna, D. D.},
